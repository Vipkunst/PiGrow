{
  "Mqtt": {
    "Host": "localhost",
    "Port": 1883,
    "Username": "user",
    "Password": "password"
  },

  "Relay": {
    "Pin": 23,
    "ActiveLow": true,
    "MinOnSeconds": 5
  },

  "ConditionChecker": {
    "RunStartupTest": true
  },

  "Conditions": {
    "SoilHumidityThreshold": { "Min": 5.0,  "Max": 20.0  },
    "HumidityThreshold":     { "Min": 40.0, "Max": 80.0  },
    "TemperatureThreshold":  { "Min": 15.0, "Max": 30.0  },
    "GasThreshold":          { "Min":  0.0, "Max": 300.0 },
    "LightThreshold":        { "Min": 20.0, "Max": 100.0 }
  },

  "TimeThresholds": {
    "TimeBetweenWateringSeconds": 3600
  },

  "Debug": {
    "Logging": {
      "LogMqttValues": true,
      "LogArduinoValues": true
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
